{
  "$schema": "https://dops.sh/theme.json",
  "name": "nord",
  "defs": {
    "nord0":  "#2e3440",
    "nord1":  "#3b4252",
    "nord2":  "#434c5e",
    "nord3":  "#4c566a",
    "nord4":  "#d8dee9",
    "nord5":  "#e5e9f0",
    "nord6":  "#eceff4",
    "nord7":  "#8fbcbb",
    "nord8":  "#88c0d0",
    "nord9":  "#81a1c1",
    "nord10": "#5e81ac",
    "nord11": "#bf616a",
    "nord12": "#d08770",
    "nord13": "#ebcb8b",
    "nord14": "#a3be8c",
    "nord15": "#b48ead",
    "snowBg":      "#eceff4",
    "snowPanel":   "#e5e9f0",
    "snowSurface": "#d8dee9",
    "snowText":    "#2e3440",
    "snowMuted":   "#4c566a",
    "snowBlue":    "#5e81ac",
    "snowGreen":   "#637a52",
    "snowOrange":  "#a5603a",
    "snowRed":     "#99424a"
  },
  "theme": {
    "background":        { "dark": "nord0",  "light": "snowBg"      },
    "backgroundPanel":   { "dark": "nord1",  "light": "snowPanel"   },
    "backgroundElement": { "dark": "nord1",  "light": "snowSurface" },
    "text":              { "dark": "nord4",  "light": "snowText"    },
    "textMuted":         { "dark": "nord3",  "light": "snowMuted"   },
    "primary":           { "dark": "nord8",  "light": "snowBlue"    },
    "border":            { "dark": "nord3",  "light": "snowMuted"   },
    "borderActive":      { "dark": "nord8",  "light": "snowBlue"    },
    "success":           { "dark": "nord14", "light": "snowGreen"   },
    "warning":           { "dark": "nord13", "light": "snowOrange"  },
    "error":             { "dark": "nord11", "light": "snowRed"     },
    "risk": {
      "low":      { "dark": "nord14", "light": "snowGreen"  },
      "medium":   { "dark": "nord13", "light": "snowOrange" },
      "high":     { "dark": "nord12", "light": "snowOrange" },
      "critical": { "dark": "nord11", "light": "snowRed"    }
    }
  }
}
